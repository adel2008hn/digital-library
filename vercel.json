{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    },
    {
      "src": "dist/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "dist/index.mjs" },
    { "src": "/uploads/(.*)", "dest": "dist/public/uploads/$1" },
    { "src": "/(.*)", "dest": "dist/index.mjs" }
  ]
}